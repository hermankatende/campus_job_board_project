DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
# Include PythonAnywhere domain + localhost for dev
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,hermankatende.pythonanywhere.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# PythonAnywhere MySQL (free tier uses MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=hermankatende$campus_jobs
DB_USER=hermankatende
DB_PASSWORD=your-mysql-password
DB_HOST=hermankatende.mysql.pythonanywhere-services.com
DB_PORT=3306

# Firebase — Option A: path to service-account.json file (upload to PythonAnywhere)
FIREBASE_CREDENTIALS_FILE=service-account.json
# Firebase — Option B: paste full JSON as one line (alternative to file)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
