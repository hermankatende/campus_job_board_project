DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
# Include your Render domain + localhost for local development
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,campus-job-board-project.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
DJANGO_CSRF_TRUSTED_ORIGINS=https://campus-job-board-project.onrender.com

# Render/Supabase Postgres via the Supabase pooler
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-postgres-password
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_SSLMODE=require

# Optional deploy-time admin bootstrap
DJANGO_SUPERUSER_USERNAME=herman
DJANGO_SUPERUSER_PASSWORD=12345herman
DJANGO_SUPERUSER_EMAIL=herman@example.com

# Firebase — Option A: path to service-account.json file in the deployed container
FIREBASE_CREDENTIALS_FILE=service-account.json
# Firebase — Option B: paste full JSON as one line
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Lecturer verification email settings
LECTURER_HOD_EMAIL=hod@example.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@gmail.com
