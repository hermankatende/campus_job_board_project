DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
# Include your Render domain + localhost for local development
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-service-name.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-service-name.onrender.com

# Option A: a single Render/Supabase Postgres URL
DATABASE_URL=postgresql://postgres:your-url-encoded-password@db.example.supabase.co:5432/postgres?sslmode=require

# Option B: explicit DB variables
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=db.example.supabase.co
DB_PORT=5432
DB_SSLMODE=require

# Firebase — Option A: path to service-account.json file in the deployed container
FIREBASE_CREDENTIALS_FILE=service-account.json
# Firebase — Option B: paste full JSON as one line
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Lecturer verification email settings
LECTURER_HOD_EMAIL=hod@example.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@gmail.com
